{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@common/*": ["src/common/*"],
      "@modules/*": ["src/modules/*"],

      "@app/*": ["src/modules/app/*"],
      "@auth/*": ["src/modules/auth/*"],
      "@user/*": ["src/modules/user/*"],
      "@jobs/*": ["src/modules/jobs/*"],
      "@school/*": ["src/modules/school/*"],
      "@membership/*": ["src/modules/membership/*"],
      "@superAdmin/*": ["src/modules/super-admin/*"],
      "@schoolAdmin/*": ["src/modules/school-admin/*"],

      "@config/*": ["src/config/*"],
      "@dtos/*": ["src/common/dto/*"],
      "@utils/*": ["src/common/utils/*"],
      "@enums/*": ["src/common/enums/*"],
      "@ctypes/*": ["src/common/types/*"],
      "@guards/*": ["src/common/guards/*"],
      "@prisma/*": ["src/modules/prisma/*"],
      "@entities/*": ["src/common/entities/*"],
      "@decorators/*": ["src/common/decorators/*"],
      "@interceptors/*": ["src/common/interceptors/*"]
    }
  },
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}
