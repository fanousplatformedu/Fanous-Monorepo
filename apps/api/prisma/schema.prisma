generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  STUDENT
  PARENT
  TEACHER
  COUNSELOR
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum OtpChannel {
  EMAIL
  SMS
}

enum OtpPurpose {
  LOGIN
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuditAction {
  SCHOOL_CREATE
  SCHOOL_UPDATE
  SCHOOL_SUSPEND
  SCHOOL_ARCHIVE
  SCHOOL_UNSUSPEND

  USER_DELETE
  ADMIN_CREATE
  ADMIN_DELETE
  USER_DISABLE
  ADMIN_DISABLE

  ACCESS_REQUEST_SUBMIT
  ACCESS_REQUEST_APPROVE
  ACCESS_REQUEST_REJECT

  AUTH_LOGOUT
  OTP_REQUEST
  AUTH_REFRESH
  OTP_VERIFY_FAIL
  AUTH_LOGIN_FAIL
  AUTH_LOGIN_SUCCESS
  OTP_VERIFY_SUCCESS

  ADMIN_PASSWORD_CHANGED
  ADMIN_PASSWORD_RESET

  MEMBER_CREATED
  GRADE_CREATE
  GRADE_UPDATE
  GRADE_ARCHIVE
  GRADE_RESTORE
  CLASSROOM_CREATE
  CLASSROOM_UPDATE
  CLASSROOM_ARCHIVE
  CLASSROOM_RESTORE
  ENROLLMENT_CREATE
  ENROLLMENT_CLOSE

  ASSIGNMENT_CREATE
  ASSIGNMENT_UPDATE
  ASSIGNMENT_PUBLISH
  ASSIGNMENT_CLOSE
  ASSIGNMENT_ASSIGN
  ASSESSMENT_SUBMIT
  ASSESSMENT_EVALUATE
  ASSESSMENT_EXPORT
}

enum AssignmentStatus {
  DRAFT
  CLOSED
  PUBLISHED
}

enum AssignmentTargetMode {
  BY_GRADE
  ALL_STUDENTS
  BY_CLASSROOM
  BY_STUDENT_IDS
}

enum StudentAssignmentStatus {
  PENDING
  SUBMITTED
  EVALUATED
  IN_PROGRESS
}

enum IntelligenceKey {
  LINGUISTIC
  LOGICAL_MATH
  MUSICAL
  BODILY_KINESTHETIC
  VISUAL_SPATIAL
  NATURALISTIC
  INTERPERSONAL
  INTRAPERSONAL
}

model School {
  id     String       @id @default(cuid())
  name   String
  code   String?      @unique
  status SchoolStatus @default(ACTIVE)

  settings Json?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  users             User[]
  accessRequests    AccessRequest[]
  otpCodes          OtpCode[]
  sessions          AuthSession[]
  auditLogs         AuditLog[]
  grades            Grade[]
  classrooms        Classroom[]
  enrollments       Enrollment[]
  schoolAssignments SchoolAssignment[]
  assessmentResults AssessmentResult[]

  @@index([status])
  @@index([createdAt])
}

model User {
  id String @id @default(cuid())

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  role   Role
  status UserStatus @default(ACTIVE)

  username     String? @unique
  passwordHash String?

  email  String?
  mobile String?

  fullName  String?
  avatarUrl String?

  forcePasswordChange Boolean   @default(false)
  lastLoginAt         DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accessRequestsSubmitted AccessRequest[]     @relation("AccessRequest_Submitter")
  accessRequestsReviewed  AccessRequest[]     @relation("AccessRequest_Reviewer")
  otpCodes                OtpCode[]
  sessions                AuthSession[]
  auditLogsAsActor        AuditLog[]          @relation("Audit_Actor")
  accessRequests          AccessRequest[]
  enrollments             Enrollment[]
  studentAssignments      StudentAssignment[]
  assessmentResults       AssessmentResult[]
  schoolAssignments       SchoolAssignment[]
  createdAssignments      SchoolAssignment[]  @relation("AssignmentCreatedBy")

  @@unique([schoolId, email])
  @@unique([schoolId, mobile])
  @@index([schoolId])
  @@index([role, status])
  @@index([email])
  @@index([mobile])
}

model AccessRequest {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  status        AccessRequestStatus @default(PENDING)
  requestedRole Role

  email  String?
  mobile String?

  fullName String?

  approvedUserId String?
  approvedUser   User?   @relation(fields: [approvedUserId], references: [id], onDelete: SetNull)

  reviewedById String?
  reviewedBy   User?   @relation("AccessRequest_Reviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  reviewedAt   DateTime?
  rejectReason String?

  submittedById String?
  submittedBy   User?   @relation("AccessRequest_Submitter", fields: [submittedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, email, status])
  @@unique([schoolId, mobile, status])
  @@index([schoolId, status])
  @@index([schoolId, requestedRole])
  @@index([createdAt])
}

model OtpCode {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel OtpChannel
  purpose OtpPurpose @default(LOGIN)

  destination String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?

  attempts    Int @default(0)
  maxAttempts Int @default(5)

  resendAfter DateTime?

  createdAt DateTime @default(now())

  @@index([schoolId, destination])
  @@index([userId])
  @@index([expiresAt])
}

model AuthSession {
  id String @id @default(cuid())

  sid String @unique

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status SessionStatus @default(ACTIVE)

  refreshTokenHash String
  parentSid        String?
  parent           AuthSession?  @relation("SessionRotation", fields: [parentSid], references: [sid], onDelete: SetNull)
  children         AuthSession[] @relation("SessionRotation")

  ip        String?
  userAgent String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId, status])
  @@index([schoolId])
  @@index([expiresAt])
}

model AuditLog {
  id String @id @default(cuid())

  action  AuditAction
  actorId String?
  actor   User?       @relation("Audit_Actor", fields: [actorId], references: [id], onDelete: SetNull)

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  entityType String?
  entityId   String?

  metadata Json?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model Grade {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name      String
  code      String?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classrooms        Classroom[]
  schoolAssignments SchoolAssignment[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
  @@index([schoolId, deletedAt])
  @@index([createdAt])
}

model Classroom {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  gradeId String
  grade   Grade  @relation(fields: [gradeId], references: [id], onDelete: Restrict)

  name      String
  code      String?
  year      Int?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments       Enrollment[]
  schoolAssignments SchoolAssignment[]

  @@unique([schoolId, gradeId, name])
  @@unique([schoolId, code])
  @@index([schoolId, gradeId, deletedAt])
  @@index([createdAt])
}

model Enrollment {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Restrict)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  startedAt DateTime
  endedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, classroomId])
  @@index([schoolId, studentId])
  @@index([startedAt, endedAt])
}

// ============== Assessment ==============
model AssessmentQuestion {
  id       String  @id @default(cuid())
  code     Int     @unique
  text     String
  order    Int
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  intelligences AssessmentQuestionIntelligence[]
  answers       StudentAnswer[]

  @@index([order])
  @@index([isActive])
}

model AssessmentQuestionIntelligence {
  id              String          @id @default(cuid())
  questionId      String
  intelligenceKey IntelligenceKey

  question AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, intelligenceKey])
  @@index([intelligenceKey])
}

model SchoolAssignment {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title       String
  description String?
  status      AssignmentStatus     @default(DRAFT)
  targetMode  AssignmentTargetMode @default(ALL_STUDENTS)

  targetGradeId String?
  targetGrade   Grade?  @relation(fields: [targetGradeId], references: [id], onDelete: SetNull)

  targetClassroomId String?
  targetClassroom   Classroom? @relation(fields: [targetClassroomId], references: [id], onDelete: SetNull)

  dueAt       DateTime?
  publishedAt DateTime?

  createdById String
  createdBy   User   @relation("AssignmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentAssignments StudentAssignment[]
  user               User?               @relation(fields: [userId], references: [id])
  userId             String?

  @@index([schoolId, status])
  @@index([createdById])
  @@index([dueAt])
  @@index([publishedAt])
}

model StudentAssignment {
  id String @id @default(cuid())

  assignmentId String
  assignment   SchoolAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  status         StudentAssignmentStatus @default(PENDING)
  startedAt      DateTime?
  submittedAt    DateTime?
  evaluatedAt    DateTime?
  completionRate Float                   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers StudentAnswer[]
  result  AssessmentResult?

  @@unique([assignmentId, studentId])
  @@index([studentId, status])
  @@index([assignmentId, status])
}

model StudentAnswer {
  id String @id @default(cuid())

  studentAssignmentId String
  studentAssignment   StudentAssignment @relation(fields: [studentAssignmentId], references: [id], onDelete: Cascade)

  questionId String
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  value Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentAssignmentId, questionId])
  @@index([questionId])
}

model AssessmentResult {
  id String @id @default(cuid())

  studentAssignmentId String            @unique
  studentAssignment   StudentAssignment @relation(fields: [studentAssignmentId], references: [id], onDelete: Cascade)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  linguistic        Float
  logicalMath       Float
  musical           Float
  bodilyKinesthetic Float
  visualSpatial     Float
  naturalistic      Float
  interpersonal     Float
  intrapersonal     Float

  dominantKey IntelligenceKey?
  summaryJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, studentId])
  @@index([dominantKey])
}
