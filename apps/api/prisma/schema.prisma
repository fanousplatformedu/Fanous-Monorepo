generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========== ENUMS - CORE / AUTH / ROLES ============
enum Role {
  PARENT
  STUDENT
  COUNSELOR
  SUPER_ADMIN
  SCHOOL_ADMIN
}

enum SchoolStatus {
  ACTIVE
  ARCHIVED
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  DELETED
  DISABLED
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum AccessRequestRole {
  PARENT
  STUDENT
  COUNSELOR
}

enum OtpChannel {
  SMS
  EMAIL
}

enum OtpPurpose {
  LOGIN
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// ========== ENUMS - AUDIT =============
enum AuditAction {
  SCHOOL_CREATE
  SCHOOL_UPDATE
  SCHOOL_SUSPEND
  SCHOOL_ARCHIVE
  SCHOOL_UNSUSPEND

  USER_DELETE
  ADMIN_CREATE
  ADMIN_DELETE
  USER_DISABLE
  ADMIN_DISABLE

  ACCESS_REQUEST_SUBMIT
  ACCESS_REQUEST_REJECT
  ACCESS_REQUEST_APPROVE

  AUTH_LOGOUT
  OTP_REQUEST
  AUTH_REFRESH
  OTP_VERIFY_FAIL
  AUTH_LOGIN_FAIL
  AUTH_LOGIN_SUCCESS
  OTP_VERIFY_SUCCESS

  ADMIN_PASSWORD_CHANGED
  ADMIN_PASSWORD_RESET

  GRADE_CREATE
  GRADE_UPDATE
  GRADE_ARCHIVE
  GRADE_RESTORE
  MEMBER_CREATED
  CLASSROOM_CREATE
  ENROLLMENT_CLOSE
  CLASSROOM_UPDATE
  CLASSROOM_ARCHIVE
  CLASSROOM_RESTORE
  ENROLLMENT_CREATE

  ASSIGNMENT_CLOSE
  ASSIGNMENT_CREATE
  ASSIGNMENT_UPDATE
  ASSIGNMENT_ASSIGN
  ASSESSMENT_SUBMIT
  ASSESSMENT_EXPORT
  ASSIGNMENT_PUBLISH
  ASSESSMENT_EVALUATE

  INAPP_NOTIFICATION_READ
  INAPP_NOTIFICATION_CREATE

  COUNSELOR_ASSIGNMENT_CREATE
  COUNSELOR_ASSIGNMENT_ARCHIVE
  COUNSELOR_ASSIGNMENT_RESTORE
}

// ============= ENUMS - ASSESSMENT / ASSIGNMENT ============
enum AssignmentStatus {
  DRAFT
  CLOSED
  PUBLISHED
}

enum AssignmentTargetMode {
  BY_GRADE
  ALL_STUDENTS
  BY_CLASSROOM
  BY_STUDENT_IDS
}

enum StudentAssignmentStatus {
  PENDING
  SUBMITTED
  EVALUATED
  IN_PROGRESS
  NOT_STARTED
}

enum IntelligenceKey {
  MUSICAL
  LINGUISTIC
  NATURALISTIC
  INTERPERSONAL
  INTRAPERSONAL
  VISUAL_SPATIAL
  BODILY_KINESTHETIC
  LOGICAL_MATHEMATICAL
}

// ============ ENUMS - STUDENT EXPERIENCE ==============
enum InAppNotificationType {
  GENERAL
  RESULT_READY
  ASSIGNMENT_DUE
  ASSIGNMENT_PUBLISHED
}

// =========== SCHOOL DOMAIN ============
model School {
  id     String       @id @default(cuid())
  name   String
  code   String?      @unique
  status SchoolStatus @default(ACTIVE)

  settings Json?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  users                   User[]
  accessRequests          AccessRequest[]
  otpCodes                OtpCode[]
  sessions                AuthSession[]
  auditLogs               AuditLog[]
  grades                  Grade[]
  classrooms              Classroom[]
  enrollments             Enrollment[]
  schoolAssignments       SchoolAssignment[]
  assessmentResults       AssessmentResult[]
  counselingSessions      CounselingSession[]
  inAppNotifications      InAppNotification[]
  parentStudentLinks      ParentStudentLink[]
  studentGradeRecords     StudentGradeRecord[]
  studentActivities       StudentActivity[]
  parentResources         ParentResource[]
  counselorStudentLinks   CounselorStudentLink[]
  counselorReviews        CounselorReview[]
  counselorNotes          CounselorNote[]
  counselorMessageThreads CounselorMessageThread[]

  @@index([status])
  @@index([createdAt])
}

// ============== USER DOMAIN ================
model User {
  id String @id @default(cuid())

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  role   Role
  status UserStatus @default(ACTIVE)

  username     String? @unique
  passwordHash String?

  email  String?
  mobile String?

  fullName  String?
  avatarUrl String?

  forcePasswordChange Boolean   @default(false)
  lastLoginAt         DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ========= RELATIONS =========
  accessRequestsSubmitted AccessRequest[] @relation("AccessRequest_Submitter")
  accessRequestsReviewed  AccessRequest[] @relation("AccessRequest_Reviewer")
  otpCodes                OtpCode[]
  sessions                AuthSession[]
  auditLogsAsActor        AuditLog[]      @relation("Audit_Actor")

  enrollments Enrollment[]

  // Assignments & Assessments
  studentAssignments StudentAssignment[]
  assessmentResults  AssessmentResult[]
  schoolAssignments  SchoolAssignment[]
  createdAssignments SchoolAssignment[]  @relation("AssignmentCreatedBy")

  // Counseling
  studentCounselingSessions   CounselingSession[] @relation("StudentCounselingSessions")
  counselorCounselingSessions CounselingSession[] @relation("CounselorCounselingSessions")
  requestedCounselingSessions CounselingSession[] @relation("RequestedCounselingSessions")

  // Notifications
  inAppNotifications InAppNotification[]

  // Parent & Student Links
  parentLinksAsParent  ParentStudentLink[] @relation("ParentLinks")
  parentLinksAsStudent ParentStudentLink[] @relation("StudentLinks")

  // Student Records
  gradeRecords        StudentGradeRecord[] @relation("StudentGradeRecords")
  activities          StudentActivity[]    @relation("StudentActivities")
  accessRequests      AccessRequest[]
  counselingSessions  CounselingSession[]
  parentStudentLinks  ParentStudentLink[]
  studentGradeRecords StudentGradeRecord[]
  studentActivities   StudentActivity[]

  // Counselor
  counselorAssignedStudents CounselorStudentLink[] @relation("CounselorAssignedStudents")
  studentAssignedCounselors CounselorStudentLink[] @relation("StudentAssignedCounselors")

  counselorReviews        CounselorReview[] @relation("CounselorReviews")
  studentCounselorReviews CounselorReview[] @relation("StudentCounselorReviews")

  counselorNotes        CounselorNote[] @relation("CounselorNotes")
  studentCounselorNotes CounselorNote[] @relation("StudentCounselorNotes")

  counselorMessageThreads CounselorMessageThread[] @relation("CounselorMessageThreads")
  studentMessageThreads   CounselorMessageThread[] @relation("StudentMessageThreads")
  counselorMessagesSent   CounselorMessage[]       @relation("CounselorMessagesSent")

  @@unique([schoolId, email])
  @@unique([schoolId, mobile])
  @@index([schoolId])
  @@index([role, status])
  @@index([email])
  @@index([mobile])
}

// =========== ACCESS REQUEST DOMAIN ==============
model AccessRequest {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  status        AccessRequestStatus @default(PENDING)
  requestedRole AccessRequestRole

  email  String?
  mobile String?

  fullName String?

  approvedUserId String?
  approvedUser   User?   @relation(fields: [approvedUserId], references: [id], onDelete: SetNull)

  reviewedById String?
  reviewedBy   User?   @relation("AccessRequest_Reviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  reviewedAt   DateTime?
  rejectReason String?

  submittedById String?
  submittedBy   User?   @relation("AccessRequest_Submitter", fields: [submittedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, email, status])
  @@unique([schoolId, mobile, status])
  @@index([schoolId, status])
  @@index([schoolId, requestedRole])
  @@index([createdAt])
}

// =========== OTP / SESSION DOMAIN ============
model OtpCode {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel OtpChannel
  purpose OtpPurpose @default(LOGIN)

  destination String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?

  attempts    Int @default(0)
  maxAttempts Int @default(5)

  resendAfter DateTime?

  createdAt DateTime @default(now())

  @@index([schoolId, destination])
  @@index([userId])
  @@index([expiresAt])
}

model AuthSession {
  id String @id @default(cuid())

  sid String @unique

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status SessionStatus @default(ACTIVE)

  refreshTokenHash String
  parentSid        String?
  parent           AuthSession?  @relation("SessionRotation", fields: [parentSid], references: [sid], onDelete: SetNull)
  children         AuthSession[] @relation("SessionRotation")

  ip        String?
  userAgent String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId, status])
  @@index([schoolId])
  @@index([expiresAt])
}

// ========= AUDIT DOMAIN ============
model AuditLog {
  id String @id @default(cuid())

  action  AuditAction
  actorId String?
  actor   User?       @relation("Audit_Actor", fields: [actorId], references: [id], onDelete: SetNull)

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  entityType String?
  entityId   String?

  metadata Json?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

// ========== SCHOOL STRUCTURE DOMAIN =============
model Grade {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name      String
  code      String?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classrooms        Classroom[]
  schoolAssignments SchoolAssignment[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
  @@index([schoolId, deletedAt])
  @@index([createdAt])
}

model Classroom {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  gradeId String
  grade   Grade  @relation(fields: [gradeId], references: [id], onDelete: Restrict)

  name      String
  code      String?
  year      Int?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments       Enrollment[]
  schoolAssignments SchoolAssignment[]

  @@unique([schoolId, gradeId, name])
  @@unique([schoolId, code])
  @@index([schoolId, gradeId, deletedAt])
  @@index([createdAt])
}

model Enrollment {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Restrict)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  startedAt DateTime
  endedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, classroomId])
  @@index([schoolId, studentId])
  @@index([startedAt, endedAt])
}

// =========== ASSESSMENT QUESTION DOMAIN ==============
model AssessmentQuestion {
  id       String  @id @default(cuid())
  code     Int     @unique
  text     String
  order    Int
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  intelligences       AssessmentQuestionIntelligence[]
  answers             StudentAnswer[]
  assignmentQuestions AssignmentQuestion[]

  @@index([order])
  @@index([isActive])
}

model AssessmentQuestionIntelligence {
  id              String          @id @default(cuid())
  questionId      String
  intelligenceKey IntelligenceKey

  question AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, intelligenceKey])
  @@index([intelligenceKey])
}

// ============= ASSIGNMENT DOMAIN =============
model AssignmentQuestion {
  id String @id @default(cuid())

  assignmentId String
  assignment   SchoolAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  sourceQuestionId String?
  sourceQuestion   AssessmentQuestion? @relation(fields: [sourceQuestionId], references: [id], onDelete: SetNull)

  order          Int
  questionNumber Int
  text           String
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers StudentAnswer[]

  @@unique([assignmentId, questionNumber])
  @@index([assignmentId, order])
  @@index([assignmentId, questionNumber])
  @@index([sourceQuestionId])
}

model SchoolAssignment {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title       String
  description String?
  status      AssignmentStatus     @default(DRAFT)
  targetMode  AssignmentTargetMode @default(ALL_STUDENTS)

  targetGradeId String?
  targetGrade   Grade?  @relation(fields: [targetGradeId], references: [id], onDelete: SetNull)

  targetClassroomId String?
  targetClassroom   Classroom? @relation(fields: [targetClassroomId], references: [id], onDelete: SetNull)

  dueAt       DateTime?
  publishedAt DateTime?

  createdById String
  createdBy   User   @relation("AssignmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentAssignments  StudentAssignment[]
  assignmentQuestions AssignmentQuestion[]
  user                User?                @relation(fields: [userId], references: [id])
  userId              String?
  counselorReviews    CounselorReview[]

  @@index([schoolId, status])
  @@index([createdById])
  @@index([dueAt])
  @@index([publishedAt])
}

// ============= STUDENT ASSIGNMENT DOMAIN ===============
model StudentAssignment {
  id String @id @default(cuid())

  assignmentId String
  assignment   SchoolAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  status         StudentAssignmentStatus @default(PENDING)
  startedAt      DateTime?
  submittedAt    DateTime?
  evaluatedAt    DateTime?
  completionRate Float                   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers StudentAnswer[]
  result  AssessmentResult?

  @@unique([assignmentId, studentId])
  @@index([studentId, status])
  @@index([assignmentId, status])
}

model StudentAnswer {
  id String @id @default(cuid())

  studentAssignmentId String
  studentAssignment   StudentAssignment @relation(fields: [studentAssignmentId], references: [id], onDelete: Cascade)

  assignmentQuestionId String
  assignmentQuestion   AssignmentQuestion @relation(fields: [assignmentQuestionId], references: [id], onDelete: Cascade)

  value Int

  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  assessmentQuestion   AssessmentQuestion? @relation(fields: [assessmentQuestionId], references: [id])
  assessmentQuestionId String?

  @@unique([studentAssignmentId, assignmentQuestionId])
  @@index([assignmentQuestionId])
}

model AssessmentResult {
  id String @id @default(cuid())

  studentAssignmentId String            @unique
  studentAssignment   StudentAssignment @relation(fields: [studentAssignmentId], references: [id], onDelete: Cascade)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  linguistic        Float
  logicalMath       Float
  musical           Float
  bodilyKinesthetic Float
  visualSpatial     Float
  naturalistic      Float
  interpersonal     Float
  intrapersonal     Float

  dominantKey IntelligenceKey?
  summaryJson Json?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  counselorReviews CounselorReview[]

  @@index([schoolId, studentId])
  @@index([dominantKey])
}

// ============ STUDENT NOTIFICATIONS ==============
model InAppNotification {
  id String @id @default(cuid())

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      InAppNotificationType
  title     String
  body      String
  actionUrl String?
  isRead    Boolean               @default(false)

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId, isRead, createdAt])
  @@index([schoolId, createdAt])
}

// =============== Counseling ===================
enum CounselingSessionStatus {
  CANCELED
  REQUESTED
  CONFIRMED
  COMPLETED
  RESCHEDULED
}

model CounselingSession {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation("StudentCounselingSessions", fields: [studentId], references: [id], onDelete: Cascade)

  counselorId String?
  counselor   User?   @relation("CounselorCounselingSessions", fields: [counselorId], references: [id], onDelete: SetNull)

  requestedById String
  requestedBy   User   @relation("RequestedCounselingSessions", fields: [requestedById], references: [id], onDelete: Cascade)

  title       String
  note        String?
  meetingUrl  String?
  scheduledAt DateTime?

  status     CounselingSessionStatus @default(REQUESTED)
  canceledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([schoolId, studentId])
  @@index([schoolId, counselorId])
  @@index([studentId, status])
  @@index([schoolId, status])
  @@index([schoolId, scheduledAt])
  @@index([counselorId, status])
}

// ================ Parent =================
enum ParentRelationType {
  OTHER
  MOTHER
  FATHER
  GUARDIAN
}

enum StudentActivityType {
  SESSION_BOOKED
  PROFILE_UPDATED
  RESULT_PUBLISHED
  SESSION_REQUESTED
  SESSION_COMPLETED
  ASSIGNMENT_STARTED
  ASSIGNMENT_ASSIGNED
  ASSIGNMENT_SUBMITTED
  ASSESSMENT_COMPLETED
  CAREER_MATCH_UPDATED
}

enum ParentResourceCategory {
  WELLBEING
  CAREER_GUIDE
  SUPPORT_TEEN
  STUDY_SUPPORT
  COMMUNICATION
}

model ParentStudentLink {
  id        String             @id @default(cuid())
  schoolId  String
  parentId  String
  studentId String
  relation  ParentRelationType @default(OTHER)
  isPrimary Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent  User    @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  student User    @relation("StudentLinks", fields: [studentId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
  userId  String?

  @@unique([parentId, studentId])
  @@index([schoolId, parentId])
  @@index([schoolId, studentId])
  @@index([parentId, isPrimary])
}

model StudentGradeRecord {
  id        String @id @default(cuid())
  schoolId  String
  studentId String

  subject    String
  score      Float
  maxScore   Float    @default(20)
  examTitle  String?
  termLabel  String?
  recordedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student User    @relation("StudentGradeRecords", fields: [studentId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
  userId  String?

  @@index([schoolId, studentId, recordedAt])
  @@index([studentId, subject])
  @@index([studentId, termLabel])
}

model StudentActivity {
  id        String @id @default(cuid())
  schoolId  String
  studentId String

  type        StudentActivityType
  title       String
  description String?
  metadata    Json?

  createdAt DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student User    @relation("StudentActivities", fields: [studentId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
  userId  String?

  @@index([schoolId, studentId, createdAt])
  @@index([studentId, type])
}

model ParentResource {
  id       String  @id @default(cuid())
  schoolId String?

  title         String
  slug          String                 @unique
  summary       String?
  content       String?
  category      ParentResourceCategory
  coverImageUrl String?
  isPublished   Boolean                @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, category, isPublished])
  @@index([isPublished, createdAt])
}

// ================ Counselor ================

enum CounselorStudentLinkStatus {
  ACTIVE
  ARCHIVED
}

enum CounselorReviewStatus {
  PENDING
  IN_REVIEW
  REVIEWED
  RETURNED
}

enum CounselorMessageSenderRole {
  COUNSELOR
  STUDENT
  PARENT
  SCHOOL_ADMIN
}

enum CounselorMessageThreadStatus {
  OPEN
  CLOSED
}

enum CounselorExportFormat {
  PDF
  EXCEL
}

model CounselorStudentLink {
  id          String                     @id @default(cuid())
  schoolId    String
  counselorId String
  studentId   String
  status      CounselorStudentLinkStatus @default(ACTIVE)
  assignedAt  DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  counselor User   @relation("CounselorAssignedStudents", fields: [counselorId], references: [id], onDelete: Cascade)
  student   User   @relation("StudentAssignedCounselors", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, counselorId, studentId])
  @@index([schoolId, counselorId, status])
  @@index([schoolId, studentId, status])
}

model CounselorReview {
  id           String                @id @default(cuid())
  schoolId     String
  counselorId  String
  studentId    String
  assignmentId String
  resultId     String?
  status       CounselorReviewStatus @default(PENDING)
  feedback     String?
  reviewedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  school     School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  counselor  User              @relation("CounselorReviews", fields: [counselorId], references: [id], onDelete: Cascade)
  student    User              @relation("StudentCounselorReviews", fields: [studentId], references: [id], onDelete: Cascade)
  assignment SchoolAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  result     AssessmentResult? @relation(fields: [resultId], references: [id], onDelete: SetNull)

  @@index([schoolId, counselorId, status])
  @@index([schoolId, studentId])
  @@index([assignmentId])
  @@index([resultId])
}

model CounselorNote {
  id          String   @id @default(cuid())
  schoolId    String
  counselorId String
  studentId   String
  title       String?
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  counselor User   @relation("CounselorNotes", fields: [counselorId], references: [id], onDelete: Cascade)
  student   User   @relation("StudentCounselorNotes", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, counselorId, studentId])
}

model CounselorMessageThread {
  id          String                       @id @default(cuid())
  schoolId    String
  counselorId String
  studentId   String
  status      CounselorMessageThreadStatus @default(OPEN)
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  school    School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  counselor User               @relation("CounselorMessageThreads", fields: [counselorId], references: [id], onDelete: Cascade)
  student   User               @relation("StudentMessageThreads", fields: [studentId], references: [id], onDelete: Cascade)
  messages  CounselorMessage[]

  @@unique([schoolId, counselorId, studentId])
  @@index([schoolId, counselorId, status])
}

model CounselorMessage {
  id         String                     @id @default(cuid())
  threadId   String
  senderId   String
  senderRole CounselorMessageSenderRole
  body       String
  isRead     Boolean                    @default(false)
  createdAt  DateTime                   @default(now())

  thread CounselorMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User                   @relation("CounselorMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderId])
}
