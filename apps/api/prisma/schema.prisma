generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======== Global roles: only system-wide power ============
enum GlobalRole {
  USER
  SUPER_ADMIN
}

// ========= School-scoped roles (per school / tenant) ==========
enum SchoolRole {
  SCHOOL_ADMIN
  STUDENT
  PARENT
  TEACHER
  COUNSELOR
}

// =========== Membership lifecycle for “admin approval” ===========
enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

// ============= OTP use-cases ==============
enum OtpPurpose {
  LOGIN
}

enum OtpChannel {
  EMAIL
  SMS
}

enum TokenType {
  REFRESH
}

// ========== SCHOOL (Tenant) ==============
model School {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserSchoolMembership[]
  otpRequests OtpRequest[]
  sessions    UserSession[]

  @@index([isActive])
}

// =========== USER (Global identity) ===========
model User {
  id String @id @default(cuid())

  email        String? @unique
  phone        String? @unique
  passwordHash String?

  globalRole GlobalRole @default(USER)
  isActive   Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserSchoolMembership[]
  otpRequests OtpRequest[]
  sessions    UserSession[]

  reviewedMemberships UserSchoolMembership[] @relation("ReviewedMemberships")

  @@index([isActive])
}

// =========== USER <-> SCHOOL membership (Tenant-scoped identity + approval)
model UserSchoolMembership {
  id String @id @default(cuid())

  userId   String
  schoolId String

  requestedRole SchoolRole
  role          SchoolRole
  status        MembershipStatus @default(PENDING)

  reviewedById String?
  reviewedAt   DateTime?

  firstName  String?
  lastName   String?
  nationalId String?
  reviewNote String?
  grade      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: userId, references: [id], onDelete: Cascade)
  school School @relation(fields: schoolId, references: [id], onDelete: Cascade)

  reviewedBy User? @relation("ReviewedMemberships", fields: reviewedById, references: [id], onDelete: SetNull)

  @@unique([userId, schoolId])
  @@index([schoolId, status])
  @@index([userId])
  @@index([schoolId, role])
}

// ======== OTP requests are school-scoped ========== 
model OtpRequest {
  id       String  @id @default(cuid())
  schoolId String?
  userId   String?

  purpose OtpPurpose
  channel OtpChannel

  email String?
  phone String?

  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)

  resendAfter DateTime?
  createdAt   DateTime  @default(now())

  school School? @relation(fields: schoolId, references: [id], onDelete: Cascade)
  user   User?   @relation(fields: userId, references: [id], onDelete: SetNull)

  @@index([schoolId, purpose])
  @@index([purpose])
  @@index([email])
  @@index([phone])
}

model UserSession {
  id String @id @default(cuid())

  userId   String
  schoolId String?

  tokenType TokenType @default(REFRESH)
  tokenHash String

  revokedAt DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: userId, references: [id], onDelete: Cascade)
  school School? @relation(fields: schoolId, references: [id], onDelete: Cascade)

  @@index([userId, schoolId])
  @@index([schoolId])
  @@index([expiresAt])
}
