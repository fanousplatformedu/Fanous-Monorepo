generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  SUPER_ADMIN
  USER
}

enum SchoolRole {
  SCHOOL_ADMIN
  STUDENT
  PARENT
  TEACHER
  COUNSELOR
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum OtpPurpose {
  LOGIN
}

enum OtpChannel {
  EMAIL
  SMS
}

enum TokenType {
  REFRESH
}

model School {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserSchoolMembership[]
  otpRequests OtpRequest[]
  sessions    UserSession[]
}

model User {
  id           String  @id @default(cuid())
  email        String? @unique
  phone        String? @unique
  passwordHash String?

  globalRole GlobalRole @default(USER)
  isActive   Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserSchoolMembership[]
  otpRequests OtpRequest[]
  sessions    UserSession[]

  reviewedMemberships UserSchoolMembership[] @relation("ReviewedMemberships")
}

model UserSchoolMembership {
  id String @id @default(cuid())

  userId   String
  schoolId String

  role   SchoolRole
  status MembershipStatus @default(PENDING)

  reviewedById String?
  reviewedAt   DateTime?

  firstName  String?
  lastName   String?
  nationalId String?
  grade      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: userId, references: [id], onDelete: Cascade)
  school School @relation(fields: schoolId, references: [id], onDelete: Cascade)

  reviewedBy User? @relation("ReviewedMemberships", fields: reviewedById, references: [id], onDelete: SetNull)

  @@unique([userId, schoolId, role])
  @@index([schoolId, status])
  @@index([userId])
}

model OtpRequest {
  id String @id @default(cuid())

  schoolId String
  userId   String?

  purpose OtpPurpose
  channel OtpChannel

  email String?
  phone String?

  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)

  resendAfter DateTime?
  createdAt   DateTime  @default(now())

  school School @relation(fields: schoolId, references: [id], onDelete: Cascade)
  user   User?  @relation(fields: userId, references: [id], onDelete: SetNull)

  @@index([schoolId, purpose])
  @@index([email])
  @@index([phone])
}

model UserSession {
  id String @id @default(cuid())

  userId   String
  schoolId String

  tokenType TokenType @default(REFRESH)
  tokenHash String

  revokedAt DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: userId, references: [id], onDelete: Cascade)
  school School @relation(fields: schoolId, references: [id], onDelete: Cascade)

  @@index([userId, schoolId])
  @@index([expiresAt])
}
