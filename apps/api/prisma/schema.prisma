generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== Roles =============
enum GlobalRole {
  USER
  SUPER_ADMIN
}

enum SchoolRole {
  SCHOOL_ADMIN
  STUDENT
  PARENT
  TEACHER
  COUNSELOR
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum OtpPurpose {
  SUPER_ADMIN_LOGIN
  SCHOOL_ADMIN_LOGIN
  USER_LOGIN
  // optional future:
  // SIGNUP_VERIFY
  // RESET_PASSWORD
}

enum OtpChannel {
  EMAIL
  SMS
}

enum TokenType {
  REFRESH
}

// =========== TENANT: School ===========
model School {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserSchoolMembership[]
  otpRequests OtpRequest[]
  sessions    UserSession[]

  @@index([isActive])
}

// =========== Global Identity: User =============
model User {
  id String @id @default(cuid())

  email           String?
  phone           String?
  passwordHash    String?
  emailNormalized String? @unique
  phoneNormalized String? @unique

  globalRole GlobalRole @default(USER)
  isActive   Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserSchoolMembership[]
  otpRequests OtpRequest[]
  sessions    UserSession[]

  reviewedMemberships UserSchoolMembership[] @relation("ReviewedMemberships")

  @@index([isActive])
  @@index([emailNormalized])
  @@index([phoneNormalized])
}

// ========== Membership ============= 
model UserSchoolMembership {
  id String @id @default(cuid())

  userId   String
  schoolId String

  requestedRole SchoolRole
  approvedRole  SchoolRole?

  status MembershipStatus @default(PENDING)

  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  firstName    String?
  lastName     String?
  nationalId   String?
  grade        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: userId, references: [id], onDelete: Cascade)
  school School @relation(fields: schoolId, references: [id], onDelete: Cascade)

  reviewedBy User? @relation("ReviewedMemberships", fields: reviewedById, references: [id], onDelete: SetNull)

  @@unique([userId, schoolId])
  @@index([schoolId, status])
  @@index([userId])
  @@index([schoolId, approvedRole])
}

// ============= OTP Requests ============= 
model OtpRequest {
  id String @id @default(cuid())

  email    String?
  phone    String?
  userId   String?
  schoolId String?

  purpose OtpPurpose
  channel OtpChannel

  emailNormalized String?
  phoneNormalized String?

  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?

  attempts Int @default(0)

  resendAfter DateTime?
  createdAt   DateTime  @default(now())

  ip        String?
  userAgent String?

  school School? @relation(fields: schoolId, references: [id], onDelete: Cascade)
  user   User?   @relation(fields: userId, references: [id], onDelete: SetNull)

  @@index([purpose, createdAt])
  @@index([schoolId, purpose, createdAt])
  @@index([emailNormalized, purpose])
  @@index([phoneNormalized, purpose])
  @@index([schoolId, emailNormalized, purpose])
  @@index([schoolId, phoneNormalized, purpose])
}

// ========== Refresh sessions ========== 
model UserSession {
  id String @id @default(cuid())

  userId   String
  schoolId String?

  tokenType TokenType @default(REFRESH)
  tokenHash String

  revokedAt DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ip        String?
  userAgent String?

  user   User    @relation(fields: userId, references: [id], onDelete: Cascade)
  school School? @relation(fields: schoolId, references: [id], onDelete: Cascade)

  @@index([userId, schoolId])
  @@index([schoolId])
  @@index([expiresAt])
}
