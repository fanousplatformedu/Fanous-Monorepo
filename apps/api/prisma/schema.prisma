generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  STUDENT
  PARENT
  TEACHER
  COUNSELOR
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum OtpChannel {
  EMAIL
  SMS
}

enum OtpPurpose {
  LOGIN
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuditAction {
  SCHOOL_CREATE
  SCHOOL_UPDATE
  SCHOOL_SUSPEND
  SCHOOL_ARCHIVE
  SCHOOL_UNSUSPEND

  USER_DELETE
  ADMIN_CREATE
  ADMIN_DELETE
  USER_DISABLE
  ADMIN_DISABLE

  ACCESS_REQUEST_SUBMIT
  ACCESS_REQUEST_APPROVE
  ACCESS_REQUEST_REJECT

  AUTH_LOGOUT
  OTP_REQUEST
  AUTH_REFRESH
  OTP_VERIFY_FAIL
  AUTH_LOGIN_FAIL
  AUTH_LOGIN_SUCCESS
  OTP_VERIFY_SUCCESS

  ADMIN_PASSWORD_CHANGED
  ADMIN_PASSWORD_RESET
}

model School {
  id     String       @id @default(cuid())
  name   String
  code   String?      @unique
  status SchoolStatus @default(ACTIVE)

  settings Json?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  users          User[]
  accessRequests AccessRequest[]
  otpCodes       OtpCode[]
  sessions       AuthSession[]
  auditLogs      AuditLog[]

  @@index([status])
  @@index([createdAt])
}

model User {
  id String @id @default(cuid())

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  role   Role
  status UserStatus @default(ACTIVE)

  username     String? @unique
  passwordHash String?

  email  String?
  mobile String?

  fullName  String?
  avatarUrl String?

  forcePasswordChange Boolean   @default(false)
  lastLoginAt         DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accessRequestsSubmitted AccessRequest[] @relation("AccessRequest_Submitter")
  accessRequestsReviewed  AccessRequest[] @relation("AccessRequest_Reviewer")
  otpCodes                OtpCode[]
  sessions                AuthSession[]
  auditLogsAsActor        AuditLog[]      @relation("Audit_Actor")
  accessRequests          AccessRequest[]

  @@unique([schoolId, email])
  @@unique([schoolId, mobile])
  @@index([schoolId])
  @@index([role, status])
  @@index([email])
  @@index([mobile])
}

model AccessRequest {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  status        AccessRequestStatus @default(PENDING)
  requestedRole Role

  email  String?
  mobile String?

  fullName String?

  approvedUserId String?
  approvedUser   User?   @relation(fields: [approvedUserId], references: [id], onDelete: SetNull)

  reviewedById String?
  reviewedBy   User?   @relation("AccessRequest_Reviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  reviewedAt   DateTime?
  rejectReason String?

  submittedById String?
  submittedBy   User?   @relation("AccessRequest_Submitter", fields: [submittedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, email, status])
  @@unique([schoolId, mobile, status])
  @@index([schoolId, status])
  @@index([schoolId, requestedRole])
  @@index([createdAt])
}

model OtpCode {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel OtpChannel
  purpose OtpPurpose @default(LOGIN)

  destination String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?

  attempts    Int @default(0)
  maxAttempts Int @default(5)

  resendAfter DateTime?

  createdAt DateTime @default(now())

  @@index([schoolId, destination])
  @@index([userId])
  @@index([expiresAt])
}

model AuthSession {
  id String @id @default(cuid())

  sid String @unique

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status SessionStatus @default(ACTIVE)

  refreshTokenHash String
  parentSid        String?
  parent           AuthSession?  @relation("SessionRotation", fields: [parentSid], references: [sid], onDelete: SetNull)
  children         AuthSession[] @relation("SessionRotation")

  ip        String?
  userAgent String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId, status])
  @@index([schoolId])
  @@index([expiresAt])
}

model AuditLog {
  id String @id @default(cuid())

  action  AuditAction
  actorId String?
  actor   User?       @relation("Audit_Actor", fields: [actorId], references: [id], onDelete: SetNull)

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  entityType String?
  entityId   String?

  metadata Json?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}
